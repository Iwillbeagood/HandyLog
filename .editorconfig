root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = tab
insert_final_newline = true
trim_trailing_whitespace = true
ktlint_function_naming_ignore_when_annotated_with = Composable, Test

[**/build/generated/**/*.{kt,kts}]
ktlint = disabled

[*.{kt,kts}]
ktlint_code_style = android_studio

# 파라미터 리스트 내 주석 관련 규칙 비활성화
ktlint_standard_discouraged-comment-location = disabled

# 기존 비활성화 목록에 filename 규칙 추가
ktlint_standard_filename = disabled

## https://pinterest.github.io/ktlint/latest/rules/standard/
# 한줄 최대 길이를 넘지 않는 선에서 함수 시그니처 작성 필수 여부
ktlint_standard_function-signature = disabled

# 한 줄의 최대 길이 제한 여부
ktlint_standard_max-line-length = disabled

# import 순서 필수 여부
ktlint_standard_import-ordering = disabled

# 주석 // 뒤에 공백 필수 여부
ktlint_standard_comment-spacing = disabled

# 메소드 시그니처의 공백 제한 여부
ktlint_standard_no-empty-first-line-in-method-block = disabled

# 중괄호 앞에 공백 제한 여부
ktlint_standard_no-blank-line-before-rbrace = disabled

# 들여쓰기와 KDoc(코틀린 문서 주석)을 제외하고, 연속된 여러 개의 공백 제한 여부
ktlint_no-multi-spaces = disabled

# 빈 클래스 바디 허용 (ktlint standard rule)
ktlint_standard_no-empty-class-body = disabled

## Intellij 속성 사용 사유 : https://slack-chats.kotlinlang.org/t/22321401/i-am-trying-to-reconfigure-out-ktlint-settings-for-a-project
# 호출부 Trailing comma 사용 필수 여부
ij_kotlin_allow_trailing_comma_on_call_site = true

# 정의부 Trailing comma 사용 필수 여부
ij_kotlin_allow_trailing_comma = true

# = 이후의 표현식이 한 줄에 맞지 않을 때, 줄바꿈 사용 필수 여부
ktlint_standard_multiline_expression_wrapping = disabled

# Class, fun 의 파라미터가 한 줄에 맞지 않을 때, 줄바꿈을 필수 여부
ktlint_standard_parameter-list-wrapping = disabled

# Wildcard import 제한 여부
ktlint_standard_no-wildcard-imports = disabled

# 파일의 마지막 줄에 개행문자 삽입 필수 여부
ktlint_standard_final-newline = disabled

# Property 이름 컨벤션 제한 여부, 첫글자 소문자, camelCase
ktlint_standard_property-naming = disabled

# 패키지명에 밑줄 허용
ktlint_standard_package-name = disabled

# Enum entry 이름 규칙 비활성화 (대문자 언더스코어 또는 UpperCamelCase 강제 경고 해제)
ktlint_standard_enum-entry-name = disabled
ktlint_standard_enum-entry-name-case = disabled

# no-empty-class-body
ktlint_standard_no-empty-class-body = disabled